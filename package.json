{
  "name": "ccmcp",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "bin": {
    "ccmcp": "bin/ccmcp"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/bundle.cjs",
    "test": "vitest run",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/bundle.cjs",
    "package": "npm run bundle && pkg dist/bundle.cjs --targets node18-linux-x64,node18-macos-x64,node18-win-x64 --output bin/ccmcp"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "esbuild": "^0.25.12",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
